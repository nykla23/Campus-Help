# 环境变量配置模板
# 复制此文件为 .env 并填写真实值（切勿将 .env 提交到仓库！）

# 服务器端口
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=<请设置强密码>
DB_NAME=campus_help

# JWT 密钥（必须设置！使用 openssl rand -base64 32 生成）
JWT_SECRET=<请生成随机密钥>

# AI 服务商 - Cloudflare Workers AI
AI_PROVIDER=cloudflare
CF_ACCOUNT_ID=<你的 Cloudflare Account ID>
CF_API_TOKEN=<你的 Cloudflare API Token>
CF_MODEL=@cf/meta/llama-3.1-8b-instruct

# CORS 允许的源（逗号分隔）
CORS_ORIGINS=http://localhost:5173
