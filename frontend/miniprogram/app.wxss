/* 全局配色（对应你的设计规范） */
:root {
  --primary-color: #1677FF; /* 主色-校园蓝 */
  --accent-color: #FF7D00;  /* 强调色-橙色 */
  --bg-color: #FFFFFF;      /* 背景白 */
  --text-main: #1D2129;     /* 正文深灰 */
  --text-aux: #86909C;      /* 辅助文字中灰 */
}

/* 全局字体（对应你的字体规范） */
page {
  font-family: PingFang SC, Source Han Sans CN;
  font-size: 16px; /* 正文默认字号 */
  background-color: var(--bg-color);
}

/* 标题样式 */
.title {
  font-size: 18px;
  font-weight: bold;
  color: var(--text-main);
}

/* 辅助文字 */
.aux-text {
  font-size: 14px;
  color: var(--text-aux);
}