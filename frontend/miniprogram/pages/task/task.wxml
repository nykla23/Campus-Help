<view class="detail-container">
  <!-- 返回栏 -->
  <view class="nav-bar">
    <image src="/images/icon-back.png" class="back-icon" bindtap="goBack" />
    <text class="nav-title">任务详情</text>
    <view class="placeholder"></view>
  </view>

  <!-- 任务头部 -->
  <view class="task-header">
    <view class="task-tag {{task.type === 0 ? 'blue' : task.type === 1 ? 'green' : task.type === 2 ? 'purple' : 'gray'}}">
      {{task.typeText}}
    </view>
    <view class="status-tag {{task.status === 0 ? 'orange' : task.status === 1 ? 'green' : task.status === 2 ? 'done' : 'cancel'}}">
      {{task.statusText}}
    </view>
  </view>

  <view class="task-title">{{task.title}}</view>
  <view class="task-coin">⭐ {{task.reward}} 虚拟币</view>

  <!-- 任务描述 -->
  <view class="section">
    <view class="section-title">任务描述</view>
    <view class="task-desc">{{task.description}}</view>
    <view class="task-info-item">
      <image src="/images/icon-location.png" class="info-icon" />
      <text>{{task.location}}</text>
    </view>
    <view class="task-info-item">
      <image src="/images/icon-time.png" class="info-icon" />
      <text>截止时间：{{task.deadline}}</text>
    </view>
    <view class="task-info-item">
      <image src="/images/icon-time.png" class="info-icon" />
      <text>发布时间：{{task.createTime}}</text>
    </view>
  </view>

  <!-- 发布者 -->
  <view class="section">
    <view class="section-title">发布者</view>
    <view class="user-card">
      <image src="{{task.publisher.avatar || '/images/default-avatar.png'}}" class="avatar" />
      <view class="user-info">
        <text class="user-name">{{task.publisher.nickname}}</text>
        <text class="credit">⭐ 信用分 {{task.publisher.credit}}</text>
      </view>
      <button class="msg-btn" bindtap="sendMsg">私信</button>
    </view>
  </view>

  <!-- 接单者（仅接单后显示） -->
  <view class="section" wx:if="{{task.acceptor && task.acceptor.id}}">
    <view class="section-title">接单者</view>
    <view class="user-card">
      <image src="{{task.acceptor.avatar}}" class="avatar" />
      <view class="user-info">
        <text class="user-name">{{task.acceptor.nickname}}</text>
        <text class="credit">⭐ 信用分 {{task.acceptor.credit}}</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮（根据状态动态显示） -->
  <view class="action-bar">
    <!-- 待接单：显示接单按钮（非发布者可见） -->
    <button wx:if="{{task.status === 0 && task.publisher.id !== userId}}" class="action-btn primary" bindtap="acceptTask">
      我要接单
    </button>
    <!-- 进行中：发布者显示完成按钮，接单者显示进行中 -->
    <button wx:if="{{task.status === 1 && task.publisher.id === userId}}" class="action-btn primary" bindtap="completeTask">
      确认完成
    </button>
    <button wx:if="{{task.status === 1 && task.acceptor.id === userId}}" class="action-btn disabled" disabled>
      进行中
    </button>
    <!-- 已完成/已取消：无操作 -->
    <button wx:if="{{task.status >= 2}}" class="action-btn disabled" disabled>
      {{task.statusText}}
    </button>
  </view>
</view>