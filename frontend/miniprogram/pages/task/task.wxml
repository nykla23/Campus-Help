<view class="detail-container">
  <!-- 返回栏 -->
  <view class="nav-bar">
    <image src="/images/icon-back.png" class="back-icon" bindtap="goBack" />
    <text class="nav-title">任务详情</text>
    <view class="placeholder"></view>
  </view>

  <!-- 任务头部 -->
  <view class="task-header">
    <view class="task-tag {{task.type === 0 ? 'blue' : task.type === 1 ? 'green' : task.type === 2 ? 'purple' : 'gray'}}">
      {{task.typeText}}
    </view>
    <view class="status-tag
      {{task.status === 0 ? 'orange' : ''}}
      {{task.status === 1 ? 'green' : ''}}
      {{task.status === 2 ? 'blue' : ''}}
      {{task.status === 3 ? 'done' : ''}}
      {{task.status === 4 ? 'cancel' : ''}}
    ">
      {{task.statusText}}
    </view>
  </view>

  <view class="task-title">{{task.title}}</view>
  <view class="task-coin">⭐ {{task.reward}} 虚拟币</view>

  <!-- 任务描述 -->
  <view class="section">
    <view class="section-title">任务描述</view>
    <view class="task-desc">{{task.description}}</view>
    <view class="task-info-item">
      <image src="/images/icon-location.png" class="info-icon" />
      <text>{{task.location}}</text>
    </view>
    <view class="task-info-item">
      <image src="/images/icon-time.png" class="info-icon" />
      <text>截止时间：{{task.deadline}}</text>
    </view>
    <view class="task-info-item">
      <image src="/images/icon-time.png" class="info-icon" />
      <text>发布时间：{{task.createTime}}</text>
    </view>
  </view>

  <!-- 发布者 -->
  <view class="section">
    <view class="section-title">发布者</view>
    <view class="user-card">
      <image src="{{task.publisher.avatar || '/images/default-avatar.png'}}" class="avatar" />
      <view class="user-info">
        <text class="user-name">{{task.publisher.nickname}}</text>
        <text class="credit">⭐ 信用分 {{task.publisher.credit}}</text>
      </view>
      <!-- 私信发布者：除了发布者自己，其他人都能发 -->
      <button  wx:if="{{task.publisher.id !== userId}}" class="msg-btn" bindtap="() => sendMsg('publisher', task.publisher.id)">
        私信
      </button>
      <!-- 发布者自己显示“我” -->
      <text wx:else class="self-tag">我</text>
    </view>
  </view>

  <!-- 接单者（仅接单后显示） -->
  <view class="section" wx:if="{{task.acceptor && task.acceptor.id}}">
    <view class="section-title">接单者</view>
    <view class="user-card">
      <image src="{{task.acceptor.avatar || '/images/default-avatar.png'}}" class="avatar" />
      <view class="user-info">
        <text class="user-name">{{task.acceptor.nickname}}</text>
        <text class="credit">⭐ 信用分 {{task.acceptor.credit}}</text>
      </view>

      <!-- 私信接单者权限控制：
           1. 发布者可私信（任务进行中/已完成）
           2. 接单者自己不显示
           3. 其他游客仅任务未完成时可看但不可私信
      -->

      <button 
        wx:if="{{task.acceptor.id !== userId && task.publisher.id === userId}}" 
        class="msg-btn" 
        bindtap="() => sendMsg('acceptor', task.acceptor.id)"
      >
        私信
      </button>
      <text wx:elif="{{task.acceptor.id === userId}}" class="self-tag">我</text>
      <!-- 非发布者/非接单者：隐藏私信按钮 -->
    </view>
  </view>

  <!-- 操作按钮（根据状态动态显示） -->
  <!-- 操作栏（按权限动态显示） -->
  <view class="action-bar">
    <!-- 待接取 (0) -->
    <block wx:if="{{task.status === 0}}">
      <button wx:if="{{task.publisher.id === userId}}" class="action-btn danger" bindtap="cancelTask">取消任务</button>
      <button wx:else class="action-btn primary" bindtap="acceptTask">接取任务</button>
    </block>

    <!-- 进行中 (1) -->
    <block wx:elif="{{task.status === 1}}">
      <!-- 接单者：提交完成 + 放弃任务 -->
      <block wx:if="{{task.acceptor && task.acceptor.id === userId}}">
        <button class="action-btn primary" bindtap="completeTask">提交完成</button>
        <button class="action-btn danger" bindtap="giveUpTask">放弃任务</button>
      </block>
      <!-- 发布者：无操作，显示提示 -->
      <view wx:elif="{{task.publisher.id === userId}}" class="waiting-text">等待接单者完成任务</view>
    </block>

    <!-- 待确认 (2) -->
    <block wx:elif="{{task.status === 2}}">
      <!-- 发布者：确认完成 -->
      <button wx:if="{{task.publisher.id === userId}}" class="action-btn primary" bindtap="confirmCompleteTask">确认完成</button>
      <!-- 接单者：等待确认 -->
      <view wx:elif="{{task.acceptor && task.acceptor.id === userId}}" class="waiting-text">等待发布者确认</view>
    </block>

    <!-- 已完成/已取消 (3/4) -->
    <block wx:else>
      <button class="action-btn disabled" disabled>{{task.statusText}}</button>
    </block>

    <!-- 联系发布者（非发布者且任务未结束） -->
    <button wx:if="{{task.publisher.id !== userId && task.status < 3}}" class="action-btn outline" bindtap="sendMsgPublisher">联系发布者</button>

    <!-- 私信接单者（仅发布者且任务进行中或待确认） -->
    <button wx:if="{{task.publisher.id === userId && task.acceptor && task.acceptor.id && (task.status === 1 || task.status === 2)}}" class="action-btn outline" bindtap="sendMsgAcceptor">私信接单者</button>
  </view>
</view>