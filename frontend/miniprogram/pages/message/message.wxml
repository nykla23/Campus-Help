<view class="message-container">
  <text class="page-title">消息</text>
  <scroll-view scroll-y class="msg-list">
    <view class="msg-item" wx:for="{{msgList}}" wx:key="id" bindtap="toChat" data-id="{{item.id}}">
      <image src="{{item.avatar}}" class="avatar" />
      <view class="msg-info">
        <view class="msg-name">{{item.nickname}}</view>
        <view class="msg-preview">{{item.preview}}</view>
      </view>
      <view class="msg-time">{{item.time}}</view>
    </view>
  </scroll-view>
</view>